      "         data  precipitacao  temperatura  temp_max  temp_min    umidade\n",
      "0  2025-01-01           7.8    21.495833      28.7      15.5  72.791667\n",
      "1  2025-01-02           0.0    21.587500      28.4      17.0  75.375000\n",
      "2  2025-01-03           1.4    20.358333      26.9      17.6  85.875000\n",
      "3  2025-01-04           2.6    20.791667      27.9      18.0  86.375000\n",
      "4  2025-01-05           4.4    22.008333      28.5      17.1  75.500000\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "\n",
    "# arquivo original\n",
    "arquivo_entrada = \"data/2025.csv\"\n",
    "\n",
    "# carregar dataset\n",
    "# separador = ;\n",
    "# decimal = ,\n",
    "df = pd.read_csv(\n",
    "    arquivo_entrada,\n",
    "    sep=';',\n",
    "    decimal=',',\n",
    "    header=None\n",
    ")\n",
    "\n",
    "# nomes das colunas usadas\n",
    "# baseado na estrutura do arquivo enviado\n",
    "colunas = {\n",
    "    0: 'data',\n",
    "    2: 'precipitacao',\n",
    "    7: 'temperatura',\n",
    "    9: 'temp_max',\n",
    "    10: 'temp_min',\n",
    "    15: 'umidade'\n",
    "}\n",
    "\n",
    "# selecionar apenas colunas necessárias\n",
    "base = df[list(colunas.keys())].rename(columns=colunas)\n",
    "\n",
    "# converter data\n",
    "base['data'] = pd.to_datetime(base['data'], format='%Y/%m/%d')\n",
    "\n",
    "# agregação diária\n",
    "resultado = (\n",
    "    base\n",
    "    .groupby(base['data'].dt.date)\n",
    "    .agg({\n",
    "        'precipitacao': 'sum',\n",
    "        'temperatura': 'mean',\n",
    "        'temp_max': 'max',\n",
    "        'temp_min': 'min',\n",
    "        'umidade': 'mean'\n",
    "    })\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "# formatar data\n",
    "resultado['data'] = pd.to_datetime(resultado['data']).dt.strftime('%Y-%m-%d')\n",
    "\n",
    "# salvar no formato desejado\n",
    "resultado.to_csv(\n",
    "    'dataset_normalizado2019.csv',\n",
    "    index=False,\n",
    "    header=False\n",
    ")\n",
    "\n",
    "print(resultado.head())"
   ]
  }
